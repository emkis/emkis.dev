---
import { metadata } from '@/metadata'

interface BaseProps {
  title: string
  description: string
}

interface WebsiteProps extends BaseProps {
  type: 'website'
}

interface ArticleProps extends BaseProps {
  type: 'article'
  publishedAt: string
  updatedAt: string
}

type Props = WebsiteProps | ArticleProps

const props = Astro.props
const canonicalUrl = new URL(Astro.url.pathname, Astro.site)
const isArticle = props.type === 'article'
const publishedAt = isArticle ? props.publishedAt : undefined
const updatedAt = isArticle ? props.updatedAt : undefined
---

<meta property="og:site_name" content={metadata.title} />
<meta property="og:title" content={props.title} />
<meta property="og:description" content={props.description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={props.type} />
{isArticle && <meta property="article:published_time" content={publishedAt} />}
{isArticle && <meta property="article:modified_time" content={updatedAt} />}
