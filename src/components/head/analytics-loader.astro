---
const isProduction = import.meta.env.PROD
---

{isProduction && (
  <Fragment>
    <script
      is:inline
      defer
      src="/js/script.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init({
        endpoint: '/api/event',
      });
    </script>
  </Fragment>
)}
  