---
import type { HTMLAttributes } from 'astro/types'

type Props = HTMLAttributes<'ol'>

const { class: className, ...restProps } = Astro.props
---

<ol {...restProps} class:list={["article-list", className]}>
  <slot />
</ol>

<style>
.article-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 24px;
}
</style>
