---
import type { HTMLTag, Polymorphic } from 'astro/types'

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }>

const { as, class: className, ...restProps } = Astro.props
const Element = as || 'div'
---

<Element {...restProps} class:list={["contain-content", className]}>
  <slot />
</Element>

<style>
.contain-content {
  font-family: "Inter", sans-serif;
  max-width: 75ch;
  margin: 0 auto;
  display: grid;
  grid-template-rows: auto 1fr auto;
  grid-template-areas: "nav" "main" "footer";
  min-height: 100svh;
  min-height: 100vh;

  /* Formula: (75ch + padding * 2) but in pixels */
  @media (max-width: 786.69px) {
    padding: 16px;
    max-width: 100%;
  }
}

.contain-content > nav {
  grid-area: nav;
}

.contain-content > main {
  grid-area: main;
}

.contain-content > footer {
  grid-area: footer;
}
</style>
